generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  name           String?
  hashedPassword String?
  systemRole     String           @default("user") // user, admin, superadmin
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  ownedWorkspaces Workspace[]     @relation("WorkspaceOwner")
  memberships    WorkspaceMember[]
  auditLogs      AuditLog[]
  overrides      OverrideLedger[]
}

model Workspace {
  id                String             @id @default(uuid())
  name              String
  ownerId           String
  owner             User               @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  members           WorkspaceMember[]
  instagramAccounts InstagramAccount[]
  products          Product[]
  campaigns         Campaign[]
  settings          Settings?
  integrationTokens IntegrationToken[]
  exports           Export[]
  rules             AutomationRule[]
  experiments       Experiment[]
  snapshots         Snapshot[]
  launches          Launch[]
  funnels           MonetizationFunnel[]
  simulations       Simulation[]
  forecasts         Forecast[]
  analyticsEvents   AnalyticsEvent[]
  learningMemories  LearningMemory[]
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String   @default("member") // admin, member, viewer, agent
  permissions String?  // JSON string for fine-grained permissions
  joinedAt    DateTime @default(now())

  @@unique([workspaceId, userId])
}

model InstagramAccount {
  id             String             @id @default(uuid())
  workspaceId    String
  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  igAccountId    String             @unique
  username       String
  profilePicUrl  String?
  accessToken    String?
  tokenExpiresAt DateTime?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  healthRecord   IntegrationHealth?
}

model IntegrationHealth {
  id                 String           @id @default(uuid())
  accountId          String           @unique
  account            InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  provider           String           @default("meta_graph")
  connectedAt        DateTime         @default(now())
  lastSuccessAt      DateTime?
  lastFailureAt      DateTime?
  expiresAt          DateTime?
  refreshAttemptedAt DateTime?
  refreshStatus      String?
  reauthRequired     Boolean          @default(false)
  healthStatus       String           @default("healthy") // healthy, expiring_soon, reauth_required, degraded, failed
  errorHistory       String? // json
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Product {
  id          String         @id @default(uuid())
  workspaceId String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  briefs      ProductBrief[]
  campaigns   Campaign[]
  launches    Launch[]
}

model ProductBrief {
  id                    String   @id @default(uuid())
  productId             String
  product               Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  niche                 String?
  topic                 String?
  targetAudience        String?
  biggestPainPoint      String?
  desiredTransformation String?
  productType           String?
  leadMagnet            String?
  ctaKeyword            String?
  founderStory          String?
  toneOfVoice           String?
  proofSnippets         String?
  doNotSayRestrictions  String?
  postingFrequency      String?
  campaignDurationDays  Int?
  approvalMode          String   @default("semi-auto") // manual, semi-auto, full-auto
  complianceNotes       String?
  brandVoiceNotes       String?
  hashtagStyle          String?
  visualStyleNotes      String?
  blueprintData         String?    // Detailed $10k AI Strategy Blueprint (JSON stringified)
  competitors           Competitor[] // Live Competitor Intelligence tracking
  agentActivities       AgentActivity[] // Logs of agents working on this brief
  intelligenceAlerts    IntelligenceAlert[] // Alerts surfaced for this brief
  executionPlans        ExecutionPlan[]
  trendSignals          TrendSignal[]
  historicalSnapshots   HistoricalSnapshot[]
  conceptVersions       ConceptBriefVersion[]
  strategyReport        StrategyReport?
  opportunityScore      OpportunityScore?
  qaReviews             QAReview[]
  workflowRuns          WorkflowRun[]
  evidenceReferences    EvidenceReference[]
  status                String   @default("draft") // draft, processing, active, archived
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Competitor {
  id               String   @id @default(uuid())
  briefId          String
  brief            ProductBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  brandName        String
  handle           String?
  website          String?
  threatScore      Int      @default(0)
  followers        Int      @default(0)
  positioning      String?
  intelligenceData String?  // JSON with SWOT, Gaps, Exploitation, Offers, Tracking
  snapshots        CompetitorSnapshot[]
  isTrackingLive   Boolean  @default(true)
  lastScannedAt    DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AgentActivity {
  id          String   @id @default(uuid())
  runId       String?  @unique
  briefId     String
  brief       ProductBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  agentName   String   // e.g., "Market Research Agent", "Opp Harvest Agent"
  task        String?  // e.g., "Scanning competitor websites", "Generating 90-Day Roadmap"
  status      String   @default("running") // running, completed, failed
  result      String?  
  confidence  Float?
  durationMs  Int?
  payloadSnapshot String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IntelligenceAlert {
  id          String   @id @default(uuid())
  briefId     String
  brief       ProductBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  level       String   // critical, high, moderate, info
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Campaign {
  id            String         @id @default(uuid())
  workspaceId   String
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  productId     String
  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  name          String
  startDate     DateTime?
  endDate       DateTime?
  ctaKeywords   String? // comma-separated
  status        String         @default("draft")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  contentAssets ContentAsset[]
  leads         Lead[]
  dmSequences   DmSequence[]
}

model ContentAsset {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  title      String
  assetType  String // caption, reel, carousel, bio, idea, comment_reply, dm_message
  status     String   @default("draft") // STRICT: draft, reviewed, approved, scheduled, published, analyzed, archived
  notes      String?

  // Media packaging support
  mediaMetadata String? // json (carousel layout, thumbnails, b-roll ideas)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  variants    AssetVariant[]
  experiments Experiment[]
}

model AssetVariant {
  id      String       @id @default(uuid())
  assetId String
  asset   ContentAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // Structured Content Pack
  variantTag String? // short, warm, evergreen
  hook       String?
  body       String?
  proof      String?
  cta        String?
  keyword    String?
  angle      String?
  notes      String?

  // Confidence & Rules Scoring
  contentQualityScore   Float? // 0.0 - 1.0
  brandFitScore         Float?
  complianceRiskScore   Float? // High is bad
  publishReadinessScore Float?
  automationConfidence  Float?
  complianceFlags       String? // json

  // Metrics
  rating    Int? // e.g. 1-5
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedules      Schedule[]
  publishedPosts PublishedPost[]
  experiment     Experiment?     @relation(fields: [experimentId], references: [id])
  experimentId   String?

  @@unique([assetId, hook]) // basic anti-duplicate constraint
}

model Schedule {
  id           String       @id @default(uuid())
  variantId    String
  variant      AssetVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  scheduledFor DateTime
  status       String       @default("pending") // pending, published, failed, cancelled
  errorLog     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model PublishedPost {
  id          String              @id @default(uuid())
  variantId   String
  variant     AssetVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  igPostId    String?             @unique
  publishedAt DateTime            @default(now())
  platformUrl String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  comments    Comment[]
  leads       Lead[]
  analytics   AnalyticsSnapshot[]
}

model Comment {
  id          String        @id @default(uuid())
  postId      String
  post        PublishedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  igCommentId String?       @unique
  username    String
  text        String
  timestamp   DateTime      @default(now())
  isLead      Boolean       @default(false)
  createdAt   DateTime      @default(now())

  @@unique([postId, username, text]) // Idempotency
  @@index([postId])
  @@index([isLead])
}

model Lead {
  id              String         @id @default(uuid())
  campaignId      String
  campaign        Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  postId          String?
  post            PublishedPost? @relation(fields: [postId], references: [id], onDelete: SetNull)
  igUsername      String
  source          String
  keywordMatched  String?
  status          String         @default("new") // strict: new, qualified, queued_dm, contacted, engaged, converted, closed
  matchConfidence Float?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  dmSequences     DmSequence[]

  @@unique([campaignId, igUsername]) // Idempotency: Prevent duplicate leads per campaign
}

model DmSequence {
  id          String    @id @default(uuid())
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  status      String    @default("pending") // strict: pending, running, halted, completed
  currentStep Int       @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  events      DmEvent[]
}

model DmEvent {
  id          String     @id @default(uuid())
  sequenceId  String
  sequence    DmSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  eventType   String
  messageText String?
  timestamp   DateTime   @default(now())
}

model AnalyticsSnapshot {
  id            String        @id @default(uuid())
  postId        String
  post          PublishedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  reach         Int           @default(0)
  likes         Int           @default(0)
  shares        Int           @default(0)
  saves         Int           @default(0)
  commentsCount Int           @default(0)
  profileVisits Int           @default(0)
  clicks        Int           @default(0)
  conversions   Int           @default(0)
  snapshotDate  DateTime      @default(now())

  @@unique([postId, snapshotDate]) // Idempotency
}

model ReviewTask {
  id            String   @id @default(uuid())
  entityType    String // asset_variant, dm_message, failed_job
  entityId      String
  reason        String
  status        String   @default("open") // strict: open, in_review, approved, rejected, resolved
  operatorNotes String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Watchdog & Dead Letter Queue
model BackgroundJob {
  id             String         @id @default(uuid())
  jobFingerprint String?        @unique // Idempotency key
  jobType        String
  payload        String? // json
  status         String         @default("pending") // strict: pending, running, retrying, failed, dead_letter, resolved
  attempts       Int            @default(0)
  maxAttempts    Int            @default(3)
  nextRetryAt    DateTime?
  error          String?
  runAt          DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  failedJob      DeadLetterJob?
}

model DeadLetterJob {
  id              String        @id @default(uuid())
  jobId           String        @unique
  job             BackgroundJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  sourceModule    String
  failureReason   String
  stackTrace      String?
  suggestedAction String?
  replayEligible  Boolean       @default(true)
  lastFailedAt    DateTime      @default(now())
  operatorNotes   String?

  @@index([replayEligible])
}

model WatchdogHeartbeat {
  id          String   @id @default(uuid())
  serviceName String   @unique // companion, scheduler
  lastPingAt  DateTime @default(now())
  status      String   @default("alive")
  metrics     String? // json buffer
}

model Settings {
  id             String    @id @default(uuid())
  workspaceId    String    @unique
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  environment    String    @default("local") // local, staging, production
  automationMode String    @default("semi-auto") // manual, semi-auto, full-auto
  globalSafeMode Boolean   @default(false)
  timezone       String    @default("UTC")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model AutomationRule {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ruleType    String // frequency_cap, compliance_block, banned_phrase, safe_mode_enforce
  ruleConfig  String // json
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Experiment {
  id            String         @id @default(uuid())
  workspaceId   String
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assetId       String?
  asset         ContentAsset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)
  name          String
  hypothesis    String
  successMetric String
  status        String         @default("running") // running, concluded
  winnerId      String?
  confidence    Float?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  variants      AssetVariant[]
}

model OverrideLedger {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  entityType String
  entityId   String
  oldValue   String? // json
  newValue   String? // json
  reason     String?
  learnFrom  Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model Snapshot {
  id           String    @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  snapshotType String // policy, generated_batch
  data         String // huge json
  operatorNote String?
  createdAt    DateTime  @default(now())
}

model IntegrationToken {
  id             String    @id @default(uuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider       String // openai, anthropic, meta_graph
  encryptedToken String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Export {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  filename    String
  s3Url       String?
  status      String    @default("processing")
  createdAt   DateTime  @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String? // json
  ipAddress String?
  createdAt DateTime @default(now())
}

// ─── MONETIZATION & BILLING ───────────────────────────────────────────────────

model Subscription {
  id                 String    @id @default(uuid())
  planId             String    @default("starter") // starter | pro | agency | enterprise
  status             String    @default("trial")   // trial | active | past_due | cancelled | paused | custom
  billingCycle       String    @default("monthly")  // monthly | annual
  trialEndsAt        DateTime?
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  mrr                Float     @default(0)          // Monthly recurring revenue in $
  customNote         String?                        // Admin override notes
  stripeCustomerId   String?
  stripeSubId        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  billingEvents      BillingEvent[]
  addOns             AddOn[]
  discounts          Discount[]
}

model UsageRecord {
  id          String   @id @default(uuid())
  metric      String   // ai_generations | scheduled_posts | social_accounts | team_members | workspaces | automation_runs | api_calls
  count       Int      @default(0)
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([metric, periodStart])
}

model BillingEvent {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  type           String       // subscription_created | plan_upgraded | plan_downgraded | payment_succeeded | payment_failed | trial_started | trial_converted | trial_expired | usage_limit_hit | addon_purchased | refund_issued | admin_override
  planId         String?
  amount         Float?
  metadata       String?      // json
  createdAt      DateTime     @default(now())
}

model AddOn {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  type           String       // ai_credits | extra_account | extra_seat | analytics_pack | white_label | priority_support | custom
  quantity       Int          @default(1)
  pricePerUnit   Float        @default(0)
  active         Boolean      @default(true)
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Discount {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  code           String?
  type           String       @default("percentage") // percentage | flat
  value          Float        // 20 = 20% or $20
  reason         String?
  appliedAt      DateTime     @default(now())
  expiresAt      DateTime?
  active         Boolean      @default(true)
}

model StrategicJobQueue {
  id          String   @id @default(uuid())
  jobType     String   // "INTAKE_AGENT", "MARKET_RESEARCH", "SCORE_COMPUTATION", etc.
  briefId     String
  payload     String?  // JSON data
  status      String   @default("pending") // pending, active, completed, failed
  lockedAt    DateTime? 
  priority    Int      @default(0)
  retries     Int      @default(0)
  errorMessage String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TrendSignal {
  id          String   @id @default(uuid())
  briefId     String
  brief       ProductBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  niche       String
  topic       String
  momentum    Float    // e.g. +1.45 (145% growth)
  signalType  String   // "emerging", "dying", "blue_ocean"
  details     String?  // JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ExecutionPlan {
  id          String   @id @default(uuid())
  briefId     String
  brief       ProductBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  type        String   // "content_plan", "funnel_tweak", "messaging_shift"
  status      String   @default("queued") // queued, applied, dismissed
  title       String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HistoricalSnapshot {
  id          String   @id @default(uuid())
  briefId     String
  brief       ProductBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  hashKey     String   
  dataType    String   
  dataContent String
  createdAt   DateTime @default(now())
}

model ConceptBriefVersion {
  id              String   @id @default(uuid())
  briefId         String
  brief           ProductBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  versionNumber   Int
  rawPayload      String   
  diffSummary     String?  
  createdAt       DateTime @default(now())
}

model CompetitorSnapshot {
  id              String   @id @default(uuid())
  competitorId    String
  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  snapshotDate    DateTime @default(now())
  metrics         CompetitorMetric[]
  positioning     CompetitorPositioning[]
}

model CompetitorMetric {
  id              String   @id @default(uuid())
  snapshotId      String
  snapshot        CompetitorSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  metricKey       String
  metricValue     String
}

model CompetitorPositioning {
  id              String   @id @default(uuid())
  snapshotId      String
  snapshot        CompetitorSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  positioningType String
  description     String
}

model StrategyReport {
  id              String   @id @default(uuid())
  briefId         String   @unique
  brief           ProductBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  overallScore    Float    @default(0)
  status          String   @default("draft") // draft, qa_pending, active, superseded
  compiledAt      DateTime?
  sections        StrategySection[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StrategySection {
  id              String   @id @default(uuid())
  reportId        String
  report          StrategyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  sectionType     String   // "market_overview", "blue_ocean", "conversion"
  content         String   
  confidenceScore Float
  lastUpdated     DateTime @default(now())
}

model OpportunityScore {
  id              String   @id @default(uuid())
  briefId         String   @unique
  brief           ProductBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  totalScore      Float
  components      ScoreComponentEntity[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ScoreComponentEntity {
  id              String   @id @default(uuid())
  scoreId         String
  score           OpportunityScore @relation(fields: [scoreId], references: [id], onDelete: Cascade)
  componentName   String   // "Demand", "Competition"
  value           Float
  reasoning       String   
}

model QAReview {
  id              String   @id @default(uuid())
  briefId         String
  brief           ProductBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  passed          Boolean
  depthScore      Float
  consistencyScore Float
  issues          QAIssue[]
  reviewedAt      DateTime @default(now())
}

model QAIssue {
  id              String   @id @default(uuid())
  reviewId        String
  review          QAReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  severity        String
  issueType       String
  description     String
}

model WorkflowRun {
  id              String   @id @default(uuid())
  briefId         String
  brief           ProductBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  triggerEvent    String
  status          String   // queued, active, completed, failed
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  errors          WorkflowError[]
}

model WorkflowError {
  id              String   @id @default(uuid())
  workflowRunId   String
  workflowRun     WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  errorCode       String
  errorMessage    String
  stackTrace      String?
  failedAt        DateTime @default(now())
}

model EvidenceReference {
  id              String   @id @default(uuid())
  briefId         String
  brief           ProductBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  sourceType      String   // URL, SERP
  sourceValue     String
}

model Launch {
  id              String   @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  name            String
  targetDate      DateTime
  status          String    @default("planning") // planning, active, completed, postponed
  revenueGoal     Float?
  simulationId    String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model MonetizationFunnel {
  id              String   @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  isLive          Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  steps           FunnelStep[]
}

model FunnelStep {
  id              String   @id @default(uuid())
  funnelId        String
  funnel          MonetizationFunnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  name            String
  stepOrder       Int
  conversionRate  Float?
  visitors        Int      @default(0)
  conversions     Int      @default(0)
}

model Simulation {
  id              String   @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  targetEvent     String   // "launch_revenue", "campaign_reach"
  parameters      String   // JSON
  results         String?  // JSON
  confidence      Float?
  status          String   @default("queued") // queued, running, completed
  createdAt       DateTime @default(now())
}

model Forecast {
  id              String   @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  metricName      String   // "mrr_growth", "audience_growth"
  horizonDays     Int      @default(30)
  predictedValue  Float
  lowerBound      Float
  upperBound      Float
  computedAt      DateTime @default(now())
}

model AnalyticsEvent {
  id              String   @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  eventType       String   // pageview, cta_click, purchase
  properties      String   // JSON
  timestamp       DateTime @default(now())
}

model LearningMemory {
  id              String   @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  context         String   // E.g., "what works for reels hooks"
  insight         String
  confidence      Float    @default(0.5)
  sourceData      String?  // JSON
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
