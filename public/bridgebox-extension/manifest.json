{
  "name": "Bridgebox Voice Capture",
  "short_name": "Bridgebox Voice",
  "version": "1.0.0",
  "manifest_version": 3,
  "description": "Capture screenshots, recordings, and DOM structure — instantly upload to Bridgebox Voice to build AI-powered software.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "desktopCapture",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bridgebox Voice Capture"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["floating-button.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
